{
  "provider": "mock",
  "openai": {
    "api_key": "",
    "base_url": "https://api.openai.com/v1",
    "default_model": "gpt-4",
    "timeout": 60,
    "max_tokens": 2048,
    "temperature": 0.7
  },
  "openrouter": {
    "api_key": "",
    "base_url": "https://openrouter.ai/api/v1",
    "default_model": "anthropic/claude-3-sonnet",
    "timeout": 60,
    "max_tokens": 2048,
    "temperature": 0.7
  },
  "agents": {
    "tariff_agent": {
      "provider": "openrouter",
      "model": "anthropic/claude-3-sonnet",
      "temperature": 0.7,
      "max_tokens": 2048,
      "system_prompt_path": "agents/tariff_agent/prompts/system_prompt.md"
    },
    "default_agent": {
      "provider": "openrouter",
      "model": "anthropic/claude-3-haiku",
      "temperature": 0.5,
      "max_tokens": 1024,
      "system_prompt_path": "agents/default_agent/prompts/system_prompt.md"
    }
  },
  "intent_classifier": {
    "provider": "openrouter",
    "model": "anthropic/claude-3-haiku",
    "temperature": 0.3,
    "max_tokens": 256
  }
}